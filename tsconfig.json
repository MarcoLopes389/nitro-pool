{
  "compilerOptions": {
    "strictNullChecks": true,
    "declaration": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitOverride": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "module": "commonjs",
    "target": "es2017",
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "types": ["node"],
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
