{
  "compilerOptions": {
    "strictNullChecks": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitOverride": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "module": "commonjs",
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "types": ["node"],
    "incremental": true,
    "skipLibCheck": true,
    "lib": [
      "ES2019",
      "DOM"
    ],
    "esModuleInterop": true,
  }
}
